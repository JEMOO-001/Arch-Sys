<Window x:Class="ArcLayoutSentinel.Views.MapSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Map to Edit"
        Height="480" Width="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow" ResizeMode="NoResize"
        Background="{DynamicResource Sentinel.WindowBackground}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ArcLayoutSentinel;component/src/ThemeResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" x:Name="HeaderBorder" Padding="24,20" BorderThickness="0,0,0,1"
                Background="{DynamicResource Sentinel.SurfaceBackground}" BorderBrush="{DynamicResource Sentinel.BorderBrush}">
            <StackPanel>
                <TextBlock Text="Select a map to edit" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Sentinel.TextPrimary}"/>
                <TextBlock Text="Choose from your previously archived maps" FontSize="13" Foreground="{DynamicResource Sentinel.TextSecondary}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" x:Name="SearchBorder" Padding="24,16" BorderThickness="0,0,0,1"
                Background="{DynamicResource Sentinel.SurfaceBackground}" BorderBrush="{DynamicResource Sentinel.BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Search" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold"
                           Foreground="{DynamicResource Sentinel.TextSecondary}"/>
                <TextBox x:Name="SearchTextBox" Grid.Column="1" Style="{DynamicResource FormTextBoxStyle}"
                         TextChanged="SearchTextBox_TextChanged"/>
                <TextBlock Grid.Column="2" x:Name="ResultCount" Text="Loading..." VerticalAlignment="Center"
                           Margin="16,0,0,0" FontSize="13" Foreground="{DynamicResource Sentinel.TextSecondary}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="4,0,4,8" Background="{DynamicResource Sentinel.SurfaceBackground}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="ID" FontWeight="Bold" FontSize="11"
                           Foreground="{DynamicResource Sentinel.TextSecondary}" Margin="12,6,0,6"/>
                <TextBlock Grid.Column="1" Text="LAYOUT" FontWeight="Bold" FontSize="11"
                           Foreground="{DynamicResource Sentinel.TextSecondary}" Margin="12,6,0,6"/>
                <TextBlock Grid.Column="2" Text="DATE" FontWeight="Bold" FontSize="11"
                           Foreground="{DynamicResource Sentinel.TextSecondary}" Margin="12,6,0,6"/>
            </Grid>
            <ListView Grid.Row="1" x:Name="MapListView"
                      SelectionMode="Single" MouseDoubleClick="MapListView_MouseDoubleClick"
                      SelectionChanged="MapListView_SelectionChanged"
                      Background="Transparent" BorderThickness="0">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding UniqueId}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Sentinel.TextPrimary}"/>
                            <TextBlock Grid.Column="1" Text="{Binding LayoutName}" FontSize="13"
                                       Foreground="{DynamicResource Sentinel.TextPrimary}"/>
                            <TextBlock Grid.Column="2" Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd}'}" FontSize="13"
                                       Foreground="{DynamicResource Sentinel.TextSecondary}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Border Grid.Row="3" x:Name="FooterBorder" Padding="24,16" BorderThickness="0,1,0,0"
                Background="{DynamicResource Sentinel.SurfaceBackground}" BorderBrush="{DynamicResource Sentinel.BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelBtn" Content="← Back" Margin="0,0,12,0"
                            Style="{DynamicResource SecondaryButtonStyle}" Click="CancelButton_Click"/>
                    <Button x:Name="SelectButton" Content="Select Map"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            IsEnabled="False" Click="SelectButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
