<Window x:Class="ArcLayoutSentinel.Views.ArchiveSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Archive Map"
        Height="360" Width="480"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        WindowStyle="SingleBorderWindow" ResizeMode="NoResize"
        Background="{DynamicResource Sentinel.WindowBackground}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ArcLayoutSentinel;component/src/ThemeResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" x:Name="HeaderBorder" Padding="24,20" BorderThickness="0,0,0,1"
                Background="{DynamicResource Sentinel.SurfaceBackground}" BorderBrush="{DynamicResource Sentinel.BorderBrush}">
            <StackPanel>
                <TextBlock Text="Archive Map" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Sentinel.TextPrimary}"/>
                <TextBlock Text="Choose an action to continue with the archival workflow" FontSize="13" Foreground="{DynamicResource Sentinel.TextSecondary}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
            <!-- Create New Card -->
            <Button x:Name="CreateNewButton" Margin="12,0" Padding="0" Cursor="Hand" BorderThickness="0"
                    Click="CreateNewButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{DynamicResource Sentinel.AccentBrush}" CornerRadius="8" Padding="24,24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Width="160">
                    <TextBlock Text="＋" FontSize="32" Foreground="{DynamicResource Sentinel.TextOnAccent}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Create New" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Sentinel.TextOnAccent}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Archive a fresh map layout for the first time" FontSize="12" Foreground="{DynamicResource Sentinel.TextOnAccent}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0" Opacity="0.85"/>
                </StackPanel>
            </Button>

            <!-- Edit Existing Card -->
            <Button x:Name="EditExistingButton" Margin="12,0" Padding="0" Cursor="Hand" BorderThickness="0"
                    Click="EditExistingButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{DynamicResource Sentinel.AccentOrange}" CornerRadius="8" Padding="24,24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Width="160">
                    <TextBlock Text="✏" FontSize="32" Foreground="{DynamicResource Sentinel.TextOnAccent}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Edit Existing" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Sentinel.TextOnAccent}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Update metadata or re-export an existing map" FontSize="12" Foreground="{DynamicResource Sentinel.TextOnAccent}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0" Opacity="0.85"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
