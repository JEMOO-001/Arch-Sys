<Window x:Class="ArcLayoutSentinel.Views.ArchiveMetadataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Archive Map"
        Height="720"
        Width="540"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        MinHeight="660" MinWidth="480"
        Background="{DynamicResource Sentinel.WindowBackground}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ArcLayoutSentinel;component/src/ThemeResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" x:Name="HeaderBorder" Padding="24,20" BorderThickness="0,0,0,1"
                Background="{DynamicResource Sentinel.SurfaceBackground}" BorderBrush="{DynamicResource Sentinel.BorderBrush}">
            <StackPanel>
                <TextBlock x:Name="HeaderTitle" Text="Archive map" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource Sentinel.TextPrimary}"/>
                <TextBlock x:Name="HeaderSubtitle" Text="Complete the details below to archive this layout" FontSize="13"
                           Foreground="{DynamicResource Sentinel.TextSecondary}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer x:Name="ContentScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource Sentinel.WindowBackground}">
            <StackPanel Margin="24,20">
                <!-- Pre-flight -->
                <Border x:Name="PreFlightBorder" Background="{DynamicResource Sentinel.SurfaceBackground}"
                        BorderBrush="{DynamicResource Sentinel.BorderBrush}" BorderThickness="1" CornerRadius="6"
                        Padding="16,12" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse x:Name="PreFlightIndicator" Width="10" Height="10" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="PreFlightText" Grid.Column="1" Text="Ready to run pre-flight check"
                                   FontSize="13" Foreground="{DynamicResource Sentinel.TextSecondary}" VerticalAlignment="Center"/>
                        <Button x:Name="PreFlightButton" Grid.Column="2" Content="Run Check" 
                                Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6"
                                Click="PreFlightButton_Click"/>
                    </Grid>
                </Border>

                <!-- Unique ID (Edit Mode Only) -->
                <StackPanel x:Name="UniqueIdPanel" Margin="0,0,0,20" Visibility="Collapsed">
                    <TextBlock Text="Unique ID" Style="{DynamicResource FormLabelStyle}"/>
                    <TextBox x:Name="UniqueIdTextBox" IsReadOnly="True" Style="{DynamicResource FormTextBoxStyle}"
                             Foreground="{DynamicResource Sentinel.TextMuted}"/>
                </StackPanel>

                <!-- Layout -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="* Select Layout" Style="{DynamicResource FormLabelStyle}"/>
                    <ComboBox x:Name="LayoutComboBox" Style="{DynamicResource FormComboBoxStyle}"/>
                </StackPanel>

                <!-- Category -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="* Category" Style="{DynamicResource FormLabelStyle}"/>
                    <Grid>
                        <ComboBox x:Name="CategoryComboBox" Style="{DynamicResource FormComboBoxStyle}"
                                  SelectionChanged="CategoryComboBox_SelectionChanged"/>
                        <TextBlock x:Name="CategoryPlaceholder" Text="— select a category —" Margin="12,0,0,0"
                                   Foreground="{DynamicResource Sentinel.TextMuted}" IsHitTestVisible="False"
                                   VerticalAlignment="Center" Visibility="Visible"/>
                    </Grid>
                </StackPanel>

                <!-- Export Format + DPI -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Export Format" Style="{DynamicResource FormLabelStyle}"/>
                        <ComboBox x:Name="ExportFormatComboBox" SelectedIndex="0" Style="{DynamicResource FormComboBoxStyle}">
                            <ComboBoxItem Content="PDF"/>
                            <ComboBoxItem Content="JPEG"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="DPI" Style="{DynamicResource FormLabelStyle}"/>
                        <ComboBox x:Name="DpiComboBox" SelectedIndex="1" Style="{DynamicResource FormComboBoxStyle}">
                            <ComboBoxItem Content="150"/>
                            <ComboBoxItem Content="300"/>
                            <ComboBoxItem Content="600"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Income Number / Outcome Number -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="* رقم الوارد" Style="{DynamicResource FormLabelStyle}"/>
                        <TextBox x:Name="IncomeNumTextBox" Style="{DynamicResource FormTextBoxStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="رقم الصادر" Style="{DynamicResource FormLabelStyle}"/>
                        <TextBox x:Name="OutcomeNumTextBox" Style="{DynamicResource FormTextBoxStyle}"/>
                    </StackPanel>
                </Grid>

                <!-- To Whom -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="* جهه الولاية" Style="{DynamicResource FormLabelStyle}"/>
                    <ComboBox x:Name="ToWhomComboBox" Style="{DynamicResource FormComboBoxStyle}">
                        <ComboBoxItem Content=""/>
                        <ComboBoxItem Content="Gov1"/>
                        <ComboBoxItem Content="Gov2"/>
                        <ComboBoxItem Content="Gov3"/>
                        <ComboBoxItem Content="Gov4"/>
                        <ComboBoxItem Content="Gov5"/>
                    </ComboBox>
                </StackPanel>

                <!-- Comment -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="ملاحظات" Style="{DynamicResource FormLabelStyle}"/>
                    <TextBox x:Name="CommentTextBox" Style="{DynamicResource FormTextBoxStyle}"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="80" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Progress Bar (collapsed until processing) -->
        <Border Grid.Row="2" x:Name="ProgressBorder" Padding="24,12"
                Background="{DynamicResource Sentinel.SurfaceBackground}" Visibility="Collapsed"
                BorderThickness="0,1,0,0" BorderBrush="{DynamicResource Sentinel.BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="ProgressText" Text="Archiving…" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource Sentinel.TextPrimary}" Margin="0,0,0,10"/>
                <ProgressBar x:Name="ProgressBar" Grid.Row="1" IsIndeterminate="True" Height="6"
                             Background="{DynamicResource Sentinel.WindowBackground}"
                             Foreground="{DynamicResource Sentinel.AccentBrush}" BorderThickness="0">
                    <ProgressBar.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </ProgressBar.Resources>
                </ProgressBar>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" x:Name="FooterBorder" Padding="24,16" BorderThickness="0,1,0,0"
                Background="{DynamicResource Sentinel.SurfaceBackground}" BorderBrush="{DynamicResource Sentinel.BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="ResultText" Text="" FontSize="13" VerticalAlignment="Center"
                           Visibility="Collapsed" TextWrapping="Wrap" Margin="0,0,16,0"
                           Foreground="{DynamicResource Sentinel.TextPrimary}"/>
                <Button Grid.Column="1" x:Name="CancelBtn" Content="Cancel" Margin="0,0,12,0"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Click="CancelButton_Click"/>
                <Button Grid.Column="2" x:Name="ArchiveBtn" Content="Archive Map"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Click="ArchiveButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
