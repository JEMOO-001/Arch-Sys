<Window x:Class="ArcLayoutSentinel.Views.LoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sentinel - Login"
        Height="360" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Topmost="True"
        Background="{DynamicResource Sentinel.WindowBackground}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ArcLayoutSentinel;component/src/ThemeResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Sentinel Login" FontWeight="Bold" FontSize="20" Margin="0,0,0,8"
                   Foreground="{DynamicResource Sentinel.TextPrimary}"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,24">
            <Ellipse x:Name="StatusIndicator" Width="10" Height="10" Fill="{DynamicResource Sentinel.TextMuted}" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" Text="Checking server status..." FontSize="12" Foreground="{DynamicResource Sentinel.TextSecondary}"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Username" Style="{DynamicResource FormLabelStyle}"/>
        <TextBox Grid.Row="3" x:Name="UsernameTextBox" Style="{DynamicResource FormTextBoxStyle}" Margin="0,0,0,16"/>

        <TextBlock Grid.Row="4" Text="Password" Style="{DynamicResource FormLabelStyle}"/>
        <PasswordBox Grid.Row="5" x:Name="PasswordBox" Padding="10,8" Margin="0,0,0,24"
                     Background="{DynamicResource Sentinel.InputBackground}" Foreground="{DynamicResource Sentinel.TextPrimary}"
                     BorderBrush="{DynamicResource Sentinel.InputBorderBrush}" BorderThickness="1">
            <PasswordBox.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </PasswordBox.Resources>
        </PasswordBox>

        <DockPanel Grid.Row="7" LastChildFill="False">
            <Button x:Name="SettingsButton" Content="⚙ Settings" Click="SettingsButton_Click"
                    Style="{DynamicResource GhostButtonStyle}" VerticalAlignment="Center"/>
            
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button x:Name="TestConnectionButton" Content="Test" Click="TestConnectionButton_Click"
                        Margin="0,0,8,0" Style="{DynamicResource SecondaryButtonStyle}"/>
                <Button x:Name="LoginButton" Content="Login" Click="LoginButton_Click"
                        Margin="0,0,8,0" IsDefault="True" Style="{DynamicResource PrimaryButtonStyle}"/>
                <Button Content="Cancel" IsCancel="True" Style="{DynamicResource SecondaryButtonStyle}"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
