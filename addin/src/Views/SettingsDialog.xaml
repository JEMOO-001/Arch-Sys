<Window x:Class="ArcLayoutSentinel.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sentinel Settings"
        Height="340" Width="480"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        WindowStyle="SingleBorderWindow" ResizeMode="NoResize"
        Background="{DynamicResource Sentinel.WindowBackground}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ArcLayoutSentinel;component/src/ThemeResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" x:Name="HeaderBorder" Padding="24,20" BorderThickness="0,0,0,1"
                Background="{DynamicResource Sentinel.SurfaceBackground}" BorderBrush="{DynamicResource Sentinel.BorderBrush}">
            <StackPanel>
                <TextBlock Text="Server Settings" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Sentinel.TextPrimary}"/>
                <TextBlock Text="Configure API server and archive storage paths" FontSize="13" Foreground="{DynamicResource Sentinel.TextSecondary}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="24,24">
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="API Server URL (Fixed)" Style="{DynamicResource FormLabelStyle}"/>
                <TextBox x:Name="BaseUrlTextBox" Style="{DynamicResource FormTextBoxStyle}" IsReadOnly="True" Background="#F5F5F5" Foreground="#888888"/>
                <TextBlock Text="This address is hardcoded for the local network." FontSize="11" Foreground="{DynamicResource Sentinel.TextMuted}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Archive Root Path (UNC)" Style="{DynamicResource FormLabelStyle}"/>
                <TextBox x:Name="ArchiveRootTextBox" Style="{DynamicResource FormTextBoxStyle}"/>
                <TextBlock Text="e.g. \\server\share\archive" FontSize="12" Foreground="{DynamicResource Sentinel.TextMuted}" Margin="0,6,0,0"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2" x:Name="FooterBorder" Padding="24,16" BorderThickness="0,1,0,0"
                Background="{DynamicResource Sentinel.SurfaceBackground}" BorderBrush="{DynamicResource Sentinel.BorderBrush}">
            <Grid>
                <TextBlock x:Name="StatusText" Text="" FontSize="13" Foreground="{DynamicResource Sentinel.SuccessBrush}" VerticalAlignment="Center" Visibility="Collapsed" Margin="0,0,16,0"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button x:Name="CancelBtn" Content="Cancel" Margin="0,0,12,0" Style="{DynamicResource SecondaryButtonStyle}" Click="CancelButton_Click"/>
                    <Button x:Name="SaveBtn" Content="Save" Style="{DynamicResource PrimaryButtonStyle}" Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
