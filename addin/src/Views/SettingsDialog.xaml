<Window x:Class="ArcLayoutSentinel.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sentinel Settings"
        Height="280"
        Width="460"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#252525">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#e6e6e6"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="Foreground" Value="#e6e6e6"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border x:Name="HeaderBorder" Grid.Row="0" Padding="20,16" BorderThickness="0,0,0,1" Background="#333333" BorderBrush="#3a3a3a">
            <StackPanel>
                <TextBlock Text="Server Settings" FontSize="15" FontWeight="Medium" Foreground="#e6e6e6"/>
                <TextBlock Text="Configure API server and archive storage paths" FontSize="12" Foreground="#999999" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="20,20">
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="API Server URL" FontSize="12" FontWeight="Medium" Foreground="#999999" Margin="0,0,0,5"/>
                <TextBox x:Name="BaseUrlTextBox" />
                <TextBlock Text="e.g. http://localhost:8000/api/v1" FontSize="11" Foreground="#666666" Margin="0,3,0,0"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Archive Root Path (UNC)" FontSize="12" FontWeight="Medium" Foreground="#999999" Margin="0,0,0,5"/>
                <TextBox x:Name="ArchiveRootTextBox" />
                <TextBlock Text="e.g. \\server\share\archive" FontSize="11" Foreground="#666666" Margin="0,3,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Footer -->
        <Border x:Name="FooterBorder" Grid.Row="2" Padding="20,12" BorderThickness="0,1,0,0" Background="#333333" BorderBrush="#3a3a3a">
            <Grid>
                <TextBlock x:Name="StatusText" Text="" FontSize="12" Foreground="#6fcf97" VerticalAlignment="Center" Visibility="Collapsed" Margin="0,0,12,0"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button x:Name="CancelBtn" Content="Cancel" Margin="0,0,8,0"
                            Padding="12,7" BorderThickness="0" Background="#444444" Foreground="#cccccc" Cursor="Hand"
                            Click="CancelButton_Click"/>
                    <Button x:Name="SaveBtn" Content="Save"
                            Background="#0078D4" Foreground="White" BorderThickness="0" Padding="18,7" Cursor="Hand"
                            Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
