<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- === Sentinel Theme Brushes === -->

    <!-- Window / Page Background -->
    <SolidColorBrush x:Key="Sentinel.WindowBackground" Color="#252525"/>
    <SolidColorBrush x:Key="Sentinel.SurfaceBackground" Color="#333333"/>
    <SolidColorBrush x:Key="Sentinel.InputBackground" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="Sentinel.CardBackground" Color="#2A2A2A"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="Sentinel.BorderBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="Sentinel.InputBorderBrush" Color="#3A3A3A"/>

    <!-- Text -->
    <SolidColorBrush x:Key="Sentinel.TextPrimary" Color="#E6E6E6"/>
    <SolidColorBrush x:Key="Sentinel.TextSecondary" Color="#999999"/>
    <SolidColorBrush x:Key="Sentinel.TextMuted" Color="#666666"/>
    <SolidColorBrush x:Key="Sentinel.TextOnAccent" Color="#FFFFFF"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="Sentinel.AccentBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="Sentinel.AccentOrange" Color="#D87E17"/>
    <SolidColorBrush x:Key="Sentinel.SuccessBrush" Color="#3B6D11"/>
    <SolidColorBrush x:Key="Sentinel.ErrorBrush" Color="#CC0000"/>
    <SolidColorBrush x:Key="Sentinel.WarningBrush" Color="#D87E17"/>

    <!-- Interactive -->
    <SolidColorBrush x:Key="Sentinel.CancelButtonBackground" Color="#444444"/>
    <SolidColorBrush x:Key="Sentinel.CancelButtonForeground" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="Sentinel.HoverBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="Sentinel.SelectedBrush" Color="#1A3A5C"/>

    <!-- Login Dialog -->
    <SolidColorBrush x:Key="Sentinel.LoginBackground" Color="#2D2D30"/>
    <SolidColorBrush x:Key="Sentinel.LoginInputBackground" Color="#3C3C3F"/>
    <SolidColorBrush x:Key="Sentinel.LoginInputBorder" Color="#5A5A5D"/>
    <SolidColorBrush x:Key="Sentinel.LoginButtonBackground" Color="#46464A"/>

    <!-- === Control Styles === -->

    <!-- Base TextBlock Style -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{DynamicResource Sentinel.TextPrimary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Form Label Style -->
    <Style x:Key="FormLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Sentinel.TextSecondary}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
    </Style>

    <!-- Input TextBox Style -->
    <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Background" Value="{DynamicResource Sentinel.InputBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Sentinel.TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Sentinel.InputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Style.Resources>
            <Style TargetType="{x:Type Border}">
                <Setter Property="CornerRadius" Value="4"/>
            </Style>
        </Style.Resources>
        <Style.Triggers>
            <Trigger Property="IsReadOnly" Value="True">
                <Setter Property="Background" Value="{DynamicResource Sentinel.SurfaceBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource Sentinel.TextMuted}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Sentinel.BorderBrush}"/>
                <Setter Property="Opacity" Value="0.6"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Form PasswordBox Style -->
    <Style x:Key="FormPasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Background" Value="{DynamicResource Sentinel.InputBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Sentinel.TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Sentinel.InputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Style.Resources>
            <Style TargetType="{x:Type Border}">
                <Setter Property="CornerRadius" Value="4"/>
            </Style>
        </Style.Resources>
    </Style>

    <!-- Form ComboBox Style -->
    <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Background" Value="{DynamicResource Sentinel.InputBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Sentinel.TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Sentinel.InputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    Background="{TemplateBinding Background}" 
                                    Grid.ColumnSpan="2" 
                                    Focusable="false" 
                                    IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="Border" CornerRadius="4" 
                                                        Background="{TemplateBinding Background}" 
                                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <Grid HorizontalAlignment="Right" Width="24">
                                                        <Path x:Name="Arrow" 
                                                              Fill="{DynamicResource Sentinel.TextSecondary}" 
                                                              Data="M 0 0 L 4 4 L 8 0 Z" 
                                                              HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="true">
                                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource Sentinel.HoverBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                        <ContentPresenter x:Name="ContentSite" 
                                          IsHitTestVisible="False" 
                                          Content="{TemplateBinding SelectionBoxItem}" 
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                          Margin="{TemplateBinding Padding}" 
                                          VerticalAlignment="Center" 
                                          HorizontalAlignment="Left"/>
                        <Popup x:Name="Popup" 
                               Placement="Bottom" 
                               IsOpen="{TemplateBinding IsDropDownOpen}" 
                               AllowsTransparency="True" 
                               Focusable="False" 
                               PopupAnimation="Slide">
                            <Grid x:Name="DropDown" 
                                  SnapsToDevicePixels="True" 
                                  MinWidth="{TemplateBinding ActualWidth}" 
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border x:Name="DropDownBorder" 
                                        Background="{DynamicResource Sentinel.SurfaceBackground}" 
                                        BorderBrush="{DynamicResource Sentinel.BorderBrush}" 
                                        BorderThickness="1" 
                                        CornerRadius="0,0,4,4" 
                                        Margin="0,2,0,0"/>
                                <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Grid>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Resources>
            <!-- Overrides for internal WPF system colors used in dropdowns -->
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{Binding Source={StaticResource Sentinel.SurfaceBackground}, Path=Color}"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{Binding Source={StaticResource Sentinel.SelectedBrush}, Path=Color}"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{Binding Source={StaticResource Sentinel.TextPrimary}, Path=Color}"/>
        </Style.Resources>
    </Style>

    <!-- ComboBox Item Style (fixes dropdown text) -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource Sentinel.TextPrimary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="10,6"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Sentinel.HoverBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Sentinel.SelectedBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource Sentinel.TextPrimary}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ListView Style for GridView alignment -->
    <Style TargetType="ListView">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,1"/>
                    <Setter Property="Background" Value="{DynamicResource Sentinel.SurfaceBackground}"/>
                    <Setter Property="Foreground" Value="{DynamicResource Sentinel.TextPrimary}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Sentinel.SelectedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Sentinel.HoverBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="GridViewColumnHeader">
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Background" Value="{DynamicResource Sentinel.SurfaceBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Sentinel.TextSecondary}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Sentinel.BorderBrush}"/>
    </Style>

    <!-- Primary Action Button Style -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Background" Value="{DynamicResource Sentinel.AccentBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource Sentinel.TextOnAccent}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="24,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Resources>
            <Style TargetType="{x:Type Border}">
                <Setter Property="CornerRadius" Value="6"/>
            </Style>
        </Style.Resources>
    </Style>

    <!-- Secondary Button Style (Cancel / Back) -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Background" Value="{DynamicResource Sentinel.CancelButtonBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Sentinel.CancelButtonForeground}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Resources>
            <Style TargetType="{x:Type Border}">
                <Setter Property="CornerRadius" Value="6"/>
            </Style>
        </Style.Resources>
    </Style>

    <!-- Ghost Button Style (transparent, for settings) -->
    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Sentinel.TextMuted}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- ListView Item Style -->
    <Style TargetType="ListViewItem">
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource Sentinel.SurfaceBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Sentinel.BorderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource Sentinel.TextPrimary}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Sentinel.SelectedBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Sentinel.AccentBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Sentinel.HoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
