<UserControl x:Class="ArcLayoutSentinel.Panes.LoginDockPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="280" d:DesignWidth="320"
             Background="#111827">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with Status -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Border Width="40" Height="40" Background="rgba(34,211,238,0.1)" CornerRadius="8" Margin="0,0,12,0" BorderBrush="#22d3ee" BorderThickness="1">
                <TextBlock Text="S" FontSize="18" FontWeight="Bold" Foreground="#22d3ee" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Sentinel" FontSize="16" FontWeight="SemiBold" Foreground="#f0f9ff"/>
                <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#22d3ee"/>
            </StackPanel>
        </StackPanel>

        <!-- Status Indicator -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                <Ellipse.Fill>
                    <SolidColorBrush Color="#22d3ee"/>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <DropShadowEffect Color="#22d3ee" BlurRadius="6" ShadowDepth="0"/>
                </Ellipse.Effect>
            </Ellipse>
            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#22d3ee" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Username -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="USERNAME" FontSize="10" Foreground="#64748b" Margin="0,0,0,6" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Padding="12,10" Background="#0d1117" Foreground="#f0f9ff" BorderBrush="#334155"
                     BorderThickness="1" CaretBrush="#22d3ee"/>
        </StackPanel>

        <!-- Password -->
        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Text="PASSWORD" FontSize="10" Foreground="#64748b" Margin="0,0,0,6" FontWeight="SemiBold"/>
            <PasswordBox x:Name="PasswordBox" Padding="12,10" Background="#0d1117" Foreground="#f0f9ff" BorderBrush="#334155" BorderThickness="1"
                         PasswordChanged="PasswordBox_PasswordChanged"/>
        </StackPanel>

        <!-- Button -->
        <Button Grid.Row="4" Content="CONNECT" Command="{Binding LoginCommand}"
                Padding="16,12" FontWeight="SemiBold" Background="#0891b2" Foreground="White"
                BorderThickness="0" Cursor="Hand" VerticalAlignment="Top"/>
    </Grid>
</UserControl>
