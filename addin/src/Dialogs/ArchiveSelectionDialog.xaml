<Window x:Class="ArcLayoutSentinel.Dialogs.ArchiveSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Archive Map"
        Height="280"
        Width="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#252525">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{Binding TextPrimaryBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" x:Name="HeaderBorder" Padding="20,16" BorderThickness="0,0,0,1" Background="#333333" BorderBrush="#3a3a3a">
            <StackPanel>
                <TextBlock Text="Archive Map" FontSize="15" FontWeight="Medium" Foreground="#e6e6e6"/>
                <TextBlock Text="Choose an action to continue" FontSize="12" Foreground="#999999" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Action Cards -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">

            <!-- Create New Card -->
            <Button x:Name="CreateNewButton" 
                    Background="#0078D4" Foreground="White" Margin="8,0"
                    Padding="16,18" Cursor="Hand" BorderThickness="0"
                    Click="CreateNewButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#0078D4" CornerRadius="6" Padding="16,18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Width="140">
                    <TextBlock Text="＋" FontSize="24" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Create new" FontSize="13" FontWeight="Medium" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Archive a fresh map layout" FontSize="11" Foreground="#cccccc"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>

            <!-- Edit Existing Card -->
            <Button x:Name="EditExistingButton" 
                    Background="#D87E17" Foreground="White" Margin="8,0"
                    Padding="16,18" Cursor="Hand" BorderThickness="0"
                    Click="EditExistingButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#D87E17" CornerRadius="6" Padding="16,18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Width="140">
                    <TextBlock Text="✏" FontSize="24" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Edit existing" FontSize="13" FontWeight="Medium" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Update an archived map" FontSize="11"
                               Foreground="#cccccc" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>