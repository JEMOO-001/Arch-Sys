<Window x:Class="ArcLayoutSentinel.Dialogs.ArchiveSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Archive Map"
        Height="280"
        Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#F3F3F3"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#323232"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#ECECEC" Padding="20,16" BorderBrush="#D9D9D9" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Archive Map" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Text="Choose an action to continue" FontSize="12" Foreground="#5E5E5E" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Action Cards -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
            
            <!-- Create New Card -->
            <Button x:Name="CreateNewButton" Style="{StaticResource ActionButton}" 
                    Background="#0078D4" Foreground="White" Margin="8,0"
                    Click="CreateNewButton_Click">
                <StackPanel Width="130">
                    <TextBlock Text="+" FontSize="32" FontWeight="Light" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Create New" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Archive a new map layout" FontSize="10" Foreground="#CCCCCC" 
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>

            <!-- Edit Existing Card -->
            <Button x:Name="EditExistingButton" Style="{StaticResource ActionButton}" 
                    Background="#D87E17" Foreground="White" Margin="8,0"
                    Click="EditExistingButton_Click">
                <StackPanel Width="130">
                    <TextBlock Text="&#x270E;" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Edit Existing" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Update an existing archived map" FontSize="10" Foreground="#E8D4B8" 
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>