<Window x:Class="ArcLayoutSentinel.Dialogs.ArchiveMetadataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Archive Map"
        Height="620"
        Width="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#252525">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#e6e6e6"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" x:Name="HeaderBorder" Padding="20,16" BorderThickness="0,0,0,1" Background="#333333" BorderBrush="#3a3a3a">
            <StackPanel>
                <TextBlock x:Name="HeaderTitle" Text="Archive map" FontSize="15" FontWeight="Medium" Foreground="#e6e6e6"/>
                <TextBlock x:Name="HeaderSubtitle" Text="Fill in metadata and archive" FontSize="12" Foreground="#999999" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#252525">
            <StackPanel Margin="20,16">
                <!-- Pre-flight -->
                <Border x:Name="PreFlightBorder" Background="#2a2a2a" BorderBrush="#3a3a3a" BorderThickness="0.5" CornerRadius="6" Padding="12,10" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse x:Name="PreFlightIndicator" Width="10" Height="10" Margin="0,0,10,0"/>
                        <TextBlock x:Name="PreFlightText" Grid.Column="1" Text="Ready to run pre-flight check" FontSize="12" Foreground="#999999" VerticalAlignment="Center"/>
                        <Button x:Name="PreFlightButton" Grid.Column="2" Content="Run check" Padding="6,5" Background="#333333" Foreground="#cccccc" BorderBrush="#444444" Cursor="Hand"
                                Click="PreFlightButton_Click"/>
                    </Grid>
                </Border>

                <!-- Unique ID (Edit Mode Only) -->
                <StackPanel x:Name="UniqueIdPanel" Margin="0,0,0,14" Visibility="Collapsed">
                    <TextBlock Text="Unique ID" FontSize="12" FontWeight="Medium" Foreground="#999999" Margin="0,0,0,5"/>
                    <TextBox x:Name="UniqueIdTextBox" IsReadOnly="True" Background="#2a2a2a" Foreground="#999999" BorderBrush="#3a3a3a"/>
                </StackPanel>

                <!-- Layout -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="* Select layout" FontSize="12" FontWeight="Medium" Foreground="#999999" Margin="0,0,0,5"/>
                    <ComboBox x:Name="LayoutComboBox" Background="#2a2a2a" Foreground="#e6e6e6" BorderBrush="#3a3a3a"/>
                </StackPanel>

                <!-- Category -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="* Category" FontSize="12" FontWeight="Medium" Foreground="#999999" Margin="0,0,0,5"/>
                    <Grid>
                        <ComboBox x:Name="CategoryComboBox" Background="#2a2a2a" Foreground="#e6e6e6" BorderBrush="#3a3a3a" SelectionChanged="CategoryComboBox_SelectionChanged"/>
                        <TextBlock x:Name="CategoryPlaceholder" Text="— select a category —" Margin="10,0,0,0" Foreground="#666666" IsHitTestVisible="False" VerticalAlignment="Center" Visibility="Visible"/>
                    </Grid>
                </StackPanel>

                <!-- Export Format + DPI -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Export format" FontSize="12" FontWeight="Medium" Foreground="#999999" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ExportFormatComboBox" SelectedIndex="0" Background="#2a2a2a" Foreground="#e6e6e6" BorderBrush="#3a3a3a">
                            <ComboBoxItem Content="PDF"/>
                            <ComboBoxItem Content="JPEG"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="DPI" FontSize="12" FontWeight="Medium" Foreground="#999999" Margin="0,0,0,5"/>
                        <ComboBox x:Name="DpiComboBox" SelectedIndex="1" Background="#2a2a2a" Foreground="#e6e6e6" BorderBrush="#3a3a3a">
                            <ComboBoxItem Content="150"/>
                            <ComboBoxItem Content="300"/>
                            <ComboBoxItem Content="600"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Income Number / Outcome Number -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
<TextBlock Text="* رقم الوارد" FontSize="12" FontWeight="Medium" Foreground="#999999" Margin="0,0,0,5"/>
                         <TextBox x:Name="IncomeNumTextBox" Background="#2a2a2a" Foreground="#e6e6e6" BorderBrush="#3a3a3a"/>
                     </StackPanel>
                     <StackPanel Grid.Column="2">
                        <TextBlock Text="رقم الصادر" FontSize="12" FontWeight="Medium" Foreground="#999999" Margin="0,0,0,5"/>
                        <TextBox x:Name="OutcomeNumTextBox" Background="#2a2a2a" Foreground="#e6e6e6" BorderBrush="#3a3a3a"/>
                    </StackPanel>
                </Grid>

                <!-- To Whom -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="* جهه الولاية" FontSize="12" FontWeight="Medium" Foreground="#999999" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ToWhomComboBox" Background="#2a2a2a" Foreground="#e6e6e6" BorderBrush="#3a3a3a">
                        <ComboBoxItem Content=""/>
                        <ComboBoxItem Content="Gov1"/>
                        <ComboBoxItem Content="Gov2"/>
                        <ComboBoxItem Content="Gov3"/>
                        <ComboBoxItem Content="Gov4"/>
                        <ComboBoxItem Content="Gov5"/>
                    </ComboBox>
                </StackPanel>

                <!-- Comment -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="ملاحظات" FontSize="12" FontWeight="Medium" Foreground="#999999" Margin="0,0,0,5"/>
                    <TextBox x:Name="CommentTextBox" Background="#2a2a2a" Foreground="#e6e6e6" BorderBrush="#3a3a3a" AcceptsReturn="True" TextWrapping="Wrap" Height="60" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" x:Name="FooterBorder" Padding="20,12" BorderThickness="0,1,0,0" Background="#333333" BorderBrush="#3a3a3a">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" x:Name="CancelBtn" Content="Cancel" Margin="0,0,8,0"
                        Padding="12,7" BorderThickness="0" Background="#444444" Foreground="#cccccc" Cursor="Hand"
                        Click="CancelButton_Click"/>
                <Button Grid.Column="2" x:Name="ArchiveButton" Content="Archive map"
                        Background="#0078D4" Foreground="White" BorderThickness="0" Padding="18,7" Cursor="Hand"
                        Click="ArchiveButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>