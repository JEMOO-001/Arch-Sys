<Window x:Class="ArcLayoutSentinel.Dialogs.ArchiveMetadataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Archive Map Metadata" 
        Height="480" 
        Width="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DialogBackgroundBrush}"
        Foreground="{DynamicResource DialogForegroundBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="DialogBackgroundBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="DialogForegroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="DialogBorderBrush" Color="#3E3E42"/>
        <SolidColorBrush x:Key="DialogInputBackgroundBrush" Color="#3C3C3F"/>
        <SolidColorBrush x:Key="DialogInputForegroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="DialogInputBorderBrush" Color="#5A5A5D"/>
        <SolidColorBrush x:Key="DialogButtonBackgroundBrush" Color="#46464A"/>
        <SolidColorBrush x:Key="DialogButtonHoverBrush" Color="#56565A"/>
        <SolidColorBrush x:Key="DialogAccentBrush" Color="#0078D4"/>
    </Window.Resources>
<Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
            <Ellipse x:Name="PreFlightIndicator" Width="10" Height="10" Margin="0,0,8,0" Fill="#666"/>
            <TextBlock x:Name="PreFlightText" Text="Pre-flight status" FontSize="11" Foreground="#999"/>
        </StackPanel>

        <Button Grid.Row="1" x:Name="PreFlightButton" Content="Run Pre-Flight Check" Click="PreFlightButton_Click" 
                HorizontalAlignment="Left" Margin="0,0,0,10" Padding="10,5" 
                Background="{DynamicResource DialogButtonBackgroundBrush}" Foreground="White" 
                BorderBrush="{DynamicResource DialogBorderBrush}" BorderThickness="1"/>

        <TextBlock Grid.Row="2" Text="Select Layout:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#CCC"/>
        <ComboBox Grid.Row="3" x:Name="LayoutComboBox" Padding="6,4" Margin="0,0,0,10" 
                 Background="{DynamicResource DialogInputBackgroundBrush}"
                 Foreground="{DynamicResource DialogInputForegroundBrush}"
                 BorderBrush="{DynamicResource DialogInputBorderBrush}"/>

        <TextBlock Grid.Row="4" Text="Category Prefix (2 letters):" FontWeight="Bold" Margin="0,0,0,5" Foreground="#CCC"/>
        <TextBox Grid.Row="5" x:Name="CategoryPrefixTextBox" Text="AB" Padding="6,4" Margin="0,0,0,10"
                 Background="{DynamicResource DialogInputBackgroundBrush}"
                 Foreground="{DynamicResource DialogInputForegroundBrush}"
                 BorderBrush="{DynamicResource DialogInputBorderBrush}"
                 BorderThickness="1" CaretBrush="White"/>

        <TextBlock Grid.Row="6" Text="Client Name:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#CCC"/>
        <TextBox Grid.Row="7" x:Name="ClientTextBox" Padding="6,4" Margin="0,0,0,10"
                 Background="{DynamicResource DialogInputBackgroundBrush}"
                 Foreground="{DynamicResource DialogInputForegroundBrush}"
                 BorderBrush="{DynamicResource DialogInputBorderBrush}"
                 BorderThickness="1" CaretBrush="White"/>

        <TextBlock Grid.Row="8" Text="Project Code:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#CCC"/>
        <TextBox Grid.Row="9" x:Name="ProjectCodeTextBox" Padding="6,4" Margin="0,0,0,10"
                 Background="{DynamicResource DialogInputBackgroundBrush}"
                 Foreground="{DynamicResource DialogInputForegroundBrush}"
                 BorderBrush="{DynamicResource DialogInputBorderBrush}"
                 BorderThickness="1" CaretBrush="White"/>

        <TextBlock Grid.Row="10" Text="Category:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#CCC"/>
        <TextBox Grid.Row="11" x:Name="CategoryTextBox" Padding="6,4" Margin="0,0,0,10"
                Background="{DynamicResource DialogInputBackgroundBrush}"
                Foreground="{DynamicResource DialogInputForegroundBrush}"
                BorderBrush="{DynamicResource DialogInputBorderBrush}"
                BorderThickness="1" CaretBrush="White"/>

        <TextBlock Grid.Row="12" Text="Export Format:" FontWeight="Bold" Margin="0,10,0,5" Foreground="#CCC"/>
        <ComboBox Grid.Row="13" x:Name="ExportFormatComboBox" Padding="6,4" Margin="0,0,0,10" SelectedIndex="0"
                 Background="{DynamicResource DialogInputBackgroundBrush}"
                 Foreground="{DynamicResource DialogInputForegroundBrush}"
                 BorderBrush="{DynamicResource DialogInputBorderBrush}">
            <ComboBoxItem Content="PDF" Foreground="White"/>
            <ComboBoxItem Content="JPEG" Foreground="White"/>
        </ComboBox>

        <Button Grid.Row="14" x:Name="ArchiveButton" Content="Archive Map" Click="ArchiveButton_Click" 
                HorizontalAlignment="Right" Padding="20,8" Margin="0,10,0,0"
                Background="{DynamicResource DialogAccentBrush}" Foreground="White" BorderBrush="{DynamicResource DialogAccentBrush}"/>
        <Button Grid.Row="14" Content="Cancel" Click="CancelButton_Click" 
                HorizontalAlignment="Left" Padding="20,8" Margin="0,10,0,0"
                Background="#46464A" Foreground="White" BorderBrush="#5A5A5D"/>
    </Grid>
</Window>