<Window x:Class="ArcLayoutSentinel.Dialogs.ArchiveMetadataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sentinel - Archive Metadata"
        Height="520"
        Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Topmost="True"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Archive Map Layout" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" Foreground="#333"/>

        <!-- Pre-Flight Status -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Ellipse x:Name="PreFlightIndicator" Width="10" Height="10" Fill="Gray" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="PreFlightText" Text="Pre-flight check pending..." FontSize="11" Foreground="#666"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Select Layout" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#444"/>
        <ComboBox Grid.Row="3" x:Name="LayoutComboBox" Padding="6,4" Margin="0,0,0,12"
                  BorderBrush="#CCC" BorderThickness="1"/>

        <TextBlock Grid.Row="4" Text="Project Code" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#444"/>
        <TextBox Grid.Row="5" x:Name="ProjectCodeTextBox" Padding="6,4" Margin="0,0,0,12"
                 BorderBrush="#CCC" BorderThickness="1"/>

        <TextBlock Grid.Row="6" Text="Client Name" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#444"/>
        <TextBox Grid.Row="7" x:Name="ClientTextBox" Padding="6,4" Margin="0,0,0,12"
                 BorderBrush="#CCC" BorderThickness="1"/>

        <TextBlock Grid.Row="8" Text="Category" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#444"/>
        <TextBox Grid.Row="9" x:Name="CategoryTextBox" Padding="6,4" Margin="0,0,0,12"
                 BorderBrush="#CCC" BorderThickness="1" Text="General"/>

        <TextBlock Grid.Row="10" Text="Category Prefix (2 letters)" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#444"/>
        <TextBox Grid.Row="11" x:Name="CategoryPrefixTextBox" Padding="6,4" Margin="0,0,0,12"
                 BorderBrush="#CCC" BorderThickness="1" Text="GN" MaxLength="2" CharacterCasing="Upper"/>

        <TextBlock Grid.Row="12" Text="Export Format" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#444"/>
        <ComboBox Grid.Row="13" x:Name="ExportFormatComboBox" Padding="6,4" Margin="0,0,0,15"
                  BorderBrush="#CCC" BorderThickness="1">
            <ComboBoxItem IsSelected="True">PDF</ComboBoxItem>
            <ComboBoxItem>JPEG</ComboBoxItem>
        </ComboBox>

        <StackPanel Grid.Row="15" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="PreFlightButton" Content="Run Pre-Flight" Click="PreFlightButton_Click"
                    Width="100" Margin="0,0,10,0" Padding="8,4" Background="#E0E0E0"/>
            <Button x:Name="ArchiveButton" Content="Archive" Click="ArchiveButton_Click"
                    Width="80" Margin="0,0,10,0" Padding="8,4" FontWeight="SemiBold"/>
            <Button Content="Cancel" IsCancel="True" Width="80" Padding="8,4"/>
        </StackPanel>
    </Grid>
</Window>
