<Window x:Class="ArcLayoutSentinel.Dialogs.MapSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Map to Edit"
        Height="500"
        Width="650"
        WindowStartupLocation="CenterOwner"
        Background="#F3F3F3"
        WindowStyle="SingleBorderWindow">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#323232"/>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#ECECEC" Padding="20,14" BorderBrush="#D9D9D9" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Select a Map to Edit" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                <TextBlock Text="Choose from your archived maps" FontSize="11" Foreground="#4A4A4A" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Search -->
        <Border Grid.Row="1" Padding="20,12" Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Search:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                <TextBox x:Name="SearchTextBox" Grid.Column="1" Padding="8,6" BorderBrush="#C8C8C8"
                         TextChanged="SearchTextBox_TextChanged"/>
                <TextBlock Grid.Column="2" x:Name="ResultCount" Text="Loading..." VerticalAlignment="Center" 
                           Margin="12,0,0,0" Foreground="#666666" FontSize="11"/>
            </Grid>
        </Border>

        <!-- Map List -->
        <ListView Grid.Row="2" x:Name="MapListView" Margin="20,12" 
                  SelectionMode="Single" MouseDoubleClick="MapListView_MouseDoubleClick"
                  SelectionChanged="MapListView_SelectionChanged">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="Margin" Value="0,2"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                    <Setter Property="Background" Value="White"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#E6F2FF"/>
                            <Setter Property="BorderBrush" Value="#0078D4"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F0F0F0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
<DataTemplate>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding UniqueId}" FontFamily="Segoe UI" FontSize="12" Foreground="#1A1A1A"/>
                    <TextBlock Grid.Column="1" Text="{Binding LayoutName}" FontFamily="Segoe UI" FontSize="12" Foreground="#1A1A1A"/>
                    <TextBlock Grid.Column="2" Text="{Binding Category}" FontFamily="Segoe UI" FontSize="12" Foreground="#1A1A1A"/>
                    <TextBlock Grid.Column="3" Text="{Binding Status}" FontFamily="Segoe UI" FontSize="12" Foreground="#1A1A1A"/>
                    <TextBlock Grid.Column="4" Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" FontFamily="Segoe UI" FontSize="12" Foreground="#1A1A1A"/>
                </Grid>
            </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#ECECEC" Padding="20,12" BorderBrush="#D9D9D9" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" Content="Cancel" Margin="0,0,8,0" 
                        Background="#5E5E5E" Foreground="White" BorderThickness="0" Padding="16,8"
                        Click="CancelButton_Click"/>
                <Button Grid.Column="2" x:Name="SelectButton" Content="Select" 
                        Background="#0078D4" Foreground="White" BorderThickness="0" Padding="16,8"
                        IsEnabled="False" Click="SelectButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>