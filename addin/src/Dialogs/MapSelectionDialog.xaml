<Window x:Class="ArcLayoutSentinel.Dialogs.MapSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Map to Edit"
        Height="440"
        Width="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#252525">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{Binding TextPrimaryBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" x:Name="HeaderBorder" Padding="20,14" BorderThickness="0,0,0,1" Background="#333333" BorderBrush="#3a3a3a">
            <StackPanel>
                <TextBlock Text="Select a map to edit" FontSize="15" FontWeight="Medium" Foreground="#e6e6e6"/>
                <TextBlock Text="Choose from your archived maps" FontSize="12" Foreground="#999999" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Search -->
        <Border Grid.Row="1" x:Name="SearchBorder" Padding="20,12" BorderThickness="0,0,0,1" Background="#2a2a2a" BorderBrush="#3a3a3a">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Search" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Medium" Foreground="#999999"/>
                <TextBox x:Name="SearchTextBox" Grid.Column="1" Padding="7,6" Background="#333333" Foreground="#e6e6e6" BorderBrush="#444444"
                         TextChanged="SearchTextBox_TextChanged"/>
                <TextBlock Grid.Column="2" x:Name="ResultCount" Text="Loading..." VerticalAlignment="Center"
                           Margin="12,0,0,0" FontSize="12" Foreground="#999999"/>
            </Grid>
        </Border>

        <!-- Map List -->
        <Grid Grid.Row="2" Margin="20,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- Column Headers -->
            <Grid Grid.Row="0" Margin="4,4" Background="#333333">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="ID" FontWeight="Medium" FontSize="11" Foreground="#999999" Margin="10,4,0,4"/>
                <TextBlock Grid.Column="1" Text="LAYOUT" FontWeight="Medium" FontSize="11" Foreground="#999999" Margin="10,4,0,4"/>
                <TextBlock Grid.Column="2" Text="DATE" FontWeight="Medium" FontSize="11" Foreground="#999999" Margin="10,4,0,4"/>
            </Grid>
            
            <ListView Grid.Row="1" x:Name="MapListView" 
                  SelectionMode="Single" MouseDoubleClick="MapListView_MouseDoubleClick"
                  SelectionChanged="MapListView_SelectionChanged">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="Margin" Value="0,2"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Background" Value="{Binding SurfaceBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Setter Property="BorderBrush" Value="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{Binding SelectedBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Setter Property="BorderBrush" Value="#0078D4"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{Binding HoverBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding UniqueId}" FontSize="13" Foreground="#e6e6e6"/>
                        <TextBlock Grid.Column="1" Text="{Binding LayoutName}" FontSize="13" Foreground="#e6e6e6"/>
                        <TextBlock Grid.Column="2" Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd}'}" FontSize="13" Foreground="#e6e6e6"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="3" x:Name="FooterBorder" Padding="20,12" BorderThickness="0,1,0,0" Background="#333333" BorderBrush="#3a3a3a">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" x:Name="CancelBtn" Content="← Back" Margin="0,0,8,0"
                        Padding="8,7" BorderThickness="0" Background="#444444" Foreground="#cccccc" Cursor="Hand"
                        Click="CancelButton_Click"/>
                <Button Grid.Column="2" x:Name="SelectButton" Content="Select"
                        Background="#0078D4" Foreground="White" BorderThickness="0" Padding="18,7"
                        IsEnabled="False" Click="SelectButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>