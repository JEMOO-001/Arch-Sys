<Window x:Class="ArcLayoutSentinel.Dialogs.LoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sentinel - Login"
        Height="300"
        Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Topmost="True"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Sentinel Login" FontWeight="Bold" FontSize="18" Margin="0,0,0,15" Foreground="#333"/>

        <!-- Server Status Indicator -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Ellipse x:Name="StatusIndicator" Width="10" Height="10" Fill="Gray" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" Text="Checking server status..." FontSize="11" Foreground="#666"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Username" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#444"/>
        <TextBox Grid.Row="3" x:Name="UsernameTextBox" Padding="6,4" Margin="0,0,0,12"
                 BorderBrush="#CCC" BorderThickness="1"/>

        <TextBlock Grid.Row="4" Text="Password" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#444"/>
        <PasswordBox Grid.Row="5" x:Name="PasswordBox" Padding="6,4" Margin="0,0,0,10"
                     BorderBrush="#CCC" BorderThickness="1"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="TestConnectionButton" Content="Test Connection" Click="TestConnectionButton_Click"
                    Width="110" Margin="0,0,10,0" Padding="8,4" Background="#E0E0E0"/>
            <Button x:Name="LoginButton" Content="Login" Click="LoginButton_Click"
                    Width="80" Margin="0,0,10,0" IsDefault="True" Padding="8,4" FontWeight="SemiBold"/>
            <Button Content="Cancel" IsCancel="True" Width="80" Padding="8,4"/>
        </StackPanel>
    </Grid>
</Window>
