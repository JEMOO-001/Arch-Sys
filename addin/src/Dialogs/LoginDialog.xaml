<Window x:Class="ArcLayoutSentinel.Dialogs.LoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sentinel - Login"
        Height="320"
        Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Topmost="True"
        Background="{DynamicResource DialogBackgroundBrush}"
        Foreground="{DynamicResource DialogForegroundBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="DialogBackgroundBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="DialogForegroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="DialogBorderBrush" Color="#3E3E42"/>
        <SolidColorBrush x:Key="DialogInputBackgroundBrush" Color="#3C3C3F"/>
        <SolidColorBrush x:Key="DialogInputForegroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="DialogInputBorderBrush" Color="#5A5A5D"/>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Sentinel Login" FontWeight="Bold" FontSize="18" Margin="0,0,0,15" 
                   Foreground="{DynamicResource DialogForegroundBrush}"/>

        <!-- Server Status Indicator -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Ellipse x:Name="StatusIndicator" Width="10" Height="10" Fill="#666" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" Text="Checking server status..." FontSize="11" Foreground="#999"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Username" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#CCC"/>
        <TextBox Grid.Row="3" x:Name="UsernameTextBox" Padding="6,4" Margin="0,0,0,12"
                 Background="{DynamicResource DialogInputBackgroundBrush}"
                 Foreground="{DynamicResource DialogInputForegroundBrush}"
                 BorderBrush="{DynamicResource DialogInputBorderBrush}"
                 BorderThickness="1"
                 CaretBrush="White"/>

        <TextBlock Grid.Row="4" Text="Password" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#CCC"/>
        <PasswordBox Grid.Row="5" x:Name="PasswordBox" Padding="6,4" Margin="0,0,0,10"
                    Background="{DynamicResource DialogInputBackgroundBrush}"
                    Foreground="{DynamicResource DialogInputForegroundBrush}"
                    BorderBrush="{DynamicResource DialogInputBorderBrush}"
                    BorderThickness="1"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="TestConnectionButton" Content="Test Connection" Click="TestConnectionButton_Click"
                    Width="110" Margin="0,0,10,0" Padding="8,6" 
                    Background="#46464A" Foreground="White" BorderBrush="#5A5A5D"/>
            <Button x:Name="LoginButton" Content="Login" Click="LoginButton_Click"
                    Width="80" Margin="0,0,10,0" IsDefault="True" Padding="8,6" FontWeight="SemiBold"
                    Background="#0078D4" Foreground="White" BorderBrush="#0078D4"/>
            <Button Content="Cancel" IsCancel="True" Width="80" Padding="8,6"
                    Background="#46464A" Foreground="White" BorderBrush="#5A5A5D"/>
        </StackPanel>
    </Grid>
</Window>