<Window x:Class="ArcLayoutSentinel.Dialogs.LoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sentinel - Login"
        Height="280"
        Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Sentinel Login" FontWeight="Bold" FontSize="18" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Username" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox Grid.Row="2" x:Name="UsernameTextBox" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="3" Text="Password" FontWeight="Bold" Margin="0,0,0,5"/>
        <PasswordBox Grid.Row="4" x:Name="PasswordBox" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="LoginButton" Content="Login" Click="LoginButton_Click" Width="80" Margin="0,0,10,0" IsDefault="True"/>
            <Button Content="Cancel" IsCancel="True" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
