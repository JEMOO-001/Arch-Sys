using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using ArcGIS.Desktop.Framework;
using ArcGIS.Desktop.Framework.Contracts;
using ArcGIS.Desktop.Framework.Threading.Tasks;
using ArcGIS.Desktop.Mapping;
using ArcGIS.Desktop.Layouts;
using ArcGIS.Desktop.Core;
using ArcLayoutSentinel.Services;
using System.Windows;

namespace ArcLayoutSentinel.Ribbon
{
    public class ArchiveButton : Button
    {
        private Dialogs.ArchiveMetadataDialog _currentDialog = null;

        protected override void OnClick()
        {
            try
            {
                // Load config
                ConfigManager.Load();

                // Check if user is logged in
                if (string.IsNullOrEmpty(ConfigManager.ApiToken))
                {
                    // Show login dialog
                    var loginDialog = new Dialogs.LoginDialog
                    {
                        Owner = FrameworkApplication.Current.MainWindow
                    };

                    System.Diagnostics.Debug.WriteLine("DEBUG: Line 37 - About to show LoginDialog");
                    bool? loginResult = loginDialog.ShowDialog();
                    System.Diagnostics.Debug.WriteLine($"DEBUG: Line 37 - LoginDialog returned: {loginResult}");
                    if (loginResult != true)
                    {
                        return; // User cancelled login
                    }
                }

                // Check for active layout
                if (LayoutView.Active == null)
                {
                    ArcGIS.Desktop.Framework.Dialogs.MessageBox.Show(
                        "No active layout view found. Please open a layout before archiving.",
                        "Sentinel Error");
                    return;
                }

                // Create dialog
                _currentDialog = new Dialogs.ArchiveMetadataDialog
                {
                    Owner = FrameworkApplication.Current.MainWindow
                };

                // Subscribe to dialog closed event
                _currentDialog.Closed += Dialog_Closed;

                // Show dialog MODAL
                bool? result = _currentDialog.ShowDialog();

                // Handle result
                if (result == true)
                {
                    ExecuteArchive(_currentDialog);
                }
            }
            catch (Exception ex)
            {
                ArcGIS.Desktop.Framework.Dialogs.MessageBox.Show(
                    $"Error opening dialog:\n{ex.Message}\n\n{ex.StackTrace}",
                    "Sentinel Error");
            }
            finally
            {
                _currentDialog = null;
            }
        }

        private void Dialog_Closed(object sender, EventArgs e)
        {
            _currentDialog = null;
        }

        private void ExecuteArchive(Dialogs.ArchiveMetadataDialog dialog)
        {
            // Execute on background thread
            QueuedTask.Run(async () =>
            {
                try
                {
                    string error = await ExecuteWorkflowAsync(dialog);

                    // Show result on UI thread
                    Application.Current.Dispatcher.Invoke(() =>
                    {
                        if (string.IsNullOrEmpty(error))
                        {
                            // Success message already shown
                        }
                        else
                        {
                            ArcGIS.Desktop.Framework.Dialogs.MessageBox.Show(error, "Sentinel Error");
                        }
                    });
                }
                catch (Exception ex)
                {
                    Application.Current.Dispatcher.Invoke(() =>
                    {
                        ArcGIS.Desktop.Framework.Dialogs.MessageBox.Show(
                            $"Error: {ex.Message}", "Sentinel Error");
                    });
                }
            });
        }

        private async Task<string> ExecuteWorkflowAsync(Dialogs.ArchiveMetadataDialog dialog)
        {
            // 1. Fetch Unique ID from API First
            string uniqueId = await ApiService.GetGenerateIdAsync(dialog.CategoryPrefix);
            if (string.IsNullOrEmpty(uniqueId))
            {
                return "Failed to generate unique ID from the server. Check your network or API token.";
            }

            // 2. Build Paths
            string archiveRoot = ConfigManager.ArchiveRoot;
            string destinationFolder = ArchivalService.GenerateDestinationFolder(archiveRoot, dialog.Category);
            string ext = dialog.ExportFormat.ToLowerInvariant() == "jpeg" ? "jpeg" : "pdf";

            string fileName = ArchivalService.GenerateFileName(
                uniqueId,
                dialog.ClientName,
                dialog.ProjectCode,
                ext
            );
            string outputPath = System.IO.Path.Combine(destinationFolder, fileName);

            // 3. Export File
            bool exported = await ExportService.ExportLayoutAsync(dialog.SelectedLayout, outputPath, dialog.ExportFormat);
            if (!exported)
            {
                return "Failed to export layout to: " + outputPath;
            }

            // 4. Register Metadata & Rollback if failed
            var mapMetadata = new
            {
                unique_id = uniqueId,
                layout_name = dialog.SelectedLayout,
                project_path = Project.Current?.URI ?? string.Empty,
                project_code = dialog.ProjectCode,
                client_name = dialog.ClientName,
                category = dialog.Category,
                status = "In Progress",
                file_path = outputPath,
                category_prefix = dialog.CategoryPrefix
            };

            var (success, error) = await ApiService.ArchiveMapAsync(mapMetadata);
            if (!success)
            {
                // Atomic Rollback
                try
                {
                    if (System.IO.File.Exists(outputPath))
                    {
                        System.IO.File.Delete(outputPath);
                    }
                }
                catch { }

                return $"API archive registration failed. The file was deleted to maintain system integrity.\n\nError: {error}";
            }

            // Success
            Application.Current.Dispatcher.Invoke(() =>
            {
                ArcGIS.Desktop.Framework.Dialogs.MessageBox.Show(
                    $"Archive completed successfully!\n\nID: {uniqueId}\nFile: {outputPath}",
                    "Sentinel Success");
            });

            return null; // No error
        }
    }
}
