using System;
using System.Net.Http;
using System.Text;
using System.Text.Json;
using System.Threading.Tasks;
using System.Windows;
using ArcGIS.Desktop.Framework;
using ArcLayoutSentinel.Services;

namespace ArcLayoutSentinel.Dialogs
{
    public partial class LoginDialog : Window
    {
        public string Username => UsernameTextBox.Text.Trim();
        public string AccessToken { get; private set; }

        public LoginDialog()
        {
            InitializeComponent();
            ConfigManager.Load();

            // Pre-fill username if saved
            if (!string.IsNullOrEmpty(ConfigManager.LastUsername))
            {
                UsernameTextBox.Text = ConfigManager.LastUsername;
            }
        }

        private void LoginButton_Click(object sender, RoutedEventArgs e)
        {
            if (string.IsNullOrWhiteSpace(Username) || string.IsNullOrWhiteSpace(PasswordBox.Password))
            {
                System.Windows.MessageBox.Show("Please enter both username and password.", "Validation Error");
                return;
            }

            // Disable button to prevent double-click
            LoginButton.IsEnabled = false;

            // Attempt login asynchronously
            TryLoginAsync(Username, PasswordBox.Password);
        }

        private async void TryLoginAsync(string username, string password)
        {
            try
            {
                bool success = await TryLoginCoreAsync(username, password);

                if (success)
                {
                    // Save username
                    ConfigManager.LastUsername = username;
                    ConfigManager.Save();

                    this.DialogResult = true;
                    this.Close();
                }
                else
                {
                    System.Windows.MessageBox.Show("Invalid username or password. Please try again.", "Login Failed");
                    LoginButton.IsEnabled = true;
                }
            }
            catch (Exception ex)
            {
                System.Windows.MessageBox.Show($"Login error: {ex.Message}", "Error");
                LoginButton.IsEnabled = true;
            }
        }

        private async Task<bool> TryLoginCoreAsync(string username, string password)
        {
            try
            {
                using (var client = new HttpClient())
                {
                    // Set a timeout to prevent hanging indefinitely
                    client.Timeout = TimeSpan.FromSeconds(10);

                    // Prepare form data
                    var content = new StringContent(
                        $"username={Uri.EscapeDataString(username)}&password={Uri.EscapeDataString(password)}",
                        Encoding.UTF8,
                        "application/x-www-form-urlencoded");

                    System.Diagnostics.Debug.WriteLine($"DEBUG: TryLoginAsync - Sending POST to {ConfigManager.BaseUrl}/auth/login");

                    // Send POST to /auth/login WITHOUT .Result
                    var response = await client.PostAsync($"{ConfigManager.BaseUrl}/auth/login", content);

                    System.Diagnostics.Debug.WriteLine($"DEBUG: TryLoginAsync - Response received: {response.StatusCode}");

                    if (response.IsSuccessStatusCode)
                    {
                        var json = await response.Content.ReadAsStringAsync();
                        using (var doc = JsonDocument.Parse(json))
                        {
                            AccessToken = doc.RootElement.GetProperty("access_token").GetString();

                            // Save token to ConfigManager
                            ConfigManager.ApiToken = AccessToken;
                            ConfigManager.Save();

                            System.Diagnostics.Debug.WriteLine("DEBUG: TryLoginAsync - Login successful");
                            return true;
                        }
                    }
                    else
                    {
                        System.Diagnostics.Debug.WriteLine($"DEBUG: TryLoginAsync - Login failed with status {response.StatusCode}");
                    }
                }
            }
            catch (TaskCanceledException)
            {
                System.Diagnostics.Debug.WriteLine("DEBUG: TryLoginAsync - Request timeout");
                System.Windows.MessageBox.Show("Login request timed out. Please check your API server.", "Timeout");
            }
            catch (HttpRequestException ex)
            {
                System.Diagnostics.Debug.WriteLine($"DEBUG: TryLoginAsync - Network error: {ex.Message}");
                System.Windows.MessageBox.Show($"Network error: {ex.Message}", "Error");
            }

            return false;
        }

        private bool TryLogin(string username, string password)
        {
            try
            {
                using (var client = new HttpClient())
                {
                    // Prepare form data
                    var content = new StringContent(
                        $"username={Uri.EscapeDataString(username)}&password={Uri.EscapeDataString(password)}",
                        Encoding.UTF8,
                        "application/x-www-form-urlencoded");

                    // Send POST to /auth/login
                    var response = client.PostAsync($"{ConfigManager.BaseUrl}/auth/login", content).Result;

                    if (response.IsSuccessStatusCode)
                    {
                        var json = response.Content.ReadAsStringAsync().Result;
                        using (var doc = JsonDocument.Parse(json))
                        {
                            AccessToken = doc.RootElement.GetProperty("access_token").GetString();

                            // Save token to ConfigManager
                            ConfigManager.ApiToken = AccessToken;
                            ConfigManager.Save();

                            return true;
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                System.Windows.MessageBox.Show($"Login error: {ex.Message}", "Error");
            }

            return false;
        }
    }
}
