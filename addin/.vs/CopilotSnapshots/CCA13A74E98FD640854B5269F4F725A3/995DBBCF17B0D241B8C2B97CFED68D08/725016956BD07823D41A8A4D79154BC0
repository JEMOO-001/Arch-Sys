<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-windows10.0.18362.0</TargetFramework>
    <SupportedOSPlatformVersion>10.0.18362.0</SupportedOSPlatformVersion>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <OutputType>Library</OutputType>
    <UseWPF>true</UseWPF>
    <ArcGISProVersion>3.0</ArcGISProVersion>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <DebugType>embedded</DebugType>
    <DebugSymbols>true</DebugSymbols>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="ArcGIS.Desktop.Framework">
      <HintPath>C:\Program Files\ArcGIS\Pro\bin\ArcGIS.Desktop.Framework.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="ArcGIS.Core">
      <HintPath>C:\Program Files\ArcGIS\Pro\bin\ArcGIS.Core.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="ArcGIS.Desktop.Layouts">
      <HintPath>C:\Program Files\ArcGIS\Pro\bin\Extensions\Layout\ArcGIS.Desktop.Layouts.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="ArcGIS.Desktop.Core">
      <HintPath>C:\Program Files\ArcGIS\Pro\bin\Extensions\Core\ArcGIS.Desktop.Core.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="ArcGIS.Desktop.Mapping">
      <HintPath>C:\Program Files\ArcGIS\Pro\bin\Extensions\Mapping\ArcGIS.Desktop.Mapping.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Content Include="src\Config.daml">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- THE FINAL STABLE PACKAGING SCRIPT -->
  <Target Name="PackageAddIn" AfterTargets="Build">
    <PropertyGroup>
      <AddInName>ArcLayoutSentinel.esriAddInX</AddInName>
      <StagingDir>$(TargetDir)staging\</StagingDir>
      <TempZip>$(TargetDir)temp_package.zip</TempZip>
      <FinalAddIn>$(TargetDir)$(AddInName)</FinalAddIn>
      <AppDataPath>$([System.Environment]::GetFolderPath(SpecialFolder.MyDocuments))</AppDataPath>
      <ProAddInFolder>$(AppDataPath)\ArcGIS\AddIns\ArcGISPro\{5f2b3df8-90f8-4f7f-a87b-9ccf9690dfc1}\</ProAddInFolder>
    </PropertyGroup>
    
    <Message Text="SENTINEL: Starting final packaging sequence..." Importance="high" />
    
    <!-- 1. Use native MSBuild tools to prep folders (100% Safe) -->
    <RemoveDir Directories="$(StagingDir)" />
    <MakeDir Directories="$(StagingDir)" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(StagingDir)" />
    <Copy SourceFiles="$(TargetDir)ArcLayoutSentinel.deps.json" DestinationFolder="$(StagingDir)" Condition="Exists('$(TargetDir)ArcLayoutSentinel.deps.json')" />
    <Copy SourceFiles="$(ProjectDir)src\Config.daml" DestinationFolder="$(StagingDir)" />
    
    <!-- 2. Simple PowerShell Zip + Rename (No complex variables) -->
    <Exec Command="powershell.exe -NoProfile -Command &quot;Remove-Item -Path '$(TempZip)', '$(FinalAddIn)' -ErrorAction SilentlyContinue; Compress-Archive -Path '$(StagingDir)*' -DestinationPath '$(TempZip)'; Move-Item -Path '$(TempZip)' -Destination '$(FinalAddIn)' -Force&quot;" />
    
    <!-- 3. Native Deployment -->
    <MakeDir Directories="$(ProAddInFolder)" />
    <Copy SourceFiles="$(FinalAddIn)" DestinationFolder="$(ProAddInFolder)" />
    
    <Message Text="SENTINEL: SUCCESS! Add-in deployed to: $(ProAddInFolder)" Importance="high" />
  </Target>

</Project>
